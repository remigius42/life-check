[Definition]
actionban = setsid sh -c 'curl -s --connect-timeout 5 --max-time 10 -X POST \
  -H '"'"'Content-Type: application/json'"'"' \
  --data "{\"text\":\"fail2ban: banned <ip> (jail: <name>) on {{ inventory_hostname }}\"}" \
  "{{ fail2ban_slack_webhook_url }}" \
  || echo "fail2ban slack notify failed for <ip>" >&2' >/dev/null &
