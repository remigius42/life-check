# spellchecker:ignore oled ttgo
# Copy this file to esphome/secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit it.
#
# Compile-time config (GPIO pin, timezone) and initial defaults for runtime-editable
# settings (message templates, thresholds, report time) are in the substitutions:
# block at the top of esphome/life-check.yaml. Runtime settings can be changed via
# the web UI after flashing without reflashing.

wifi_ssid: "YourSSID"
wifi_password: "YourWiFiPassword"

ota_password: "choose-a-strong-ota-password"

web_username: "admin"
web_password: "choose-a-strong-web-password"

# Slack incoming webhook URL (or any HTTP endpoint accepting {"text": "..."})
webhook_url: "https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX"
