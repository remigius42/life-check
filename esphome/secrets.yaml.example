# spellchecker:ignore oled ttgo
# Copy this file to esphome/secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit it.

wifi_ssid: "YourSSID"
wifi_password: "YourWiFiPassword"

ota_password: "choose-a-strong-ota-password"

web_username: "admin"
web_password: "choose-a-strong-web-password"

# POSIX timezone string — find yours at https://github.com/nayarsystems/posix_tz_db/blob/master/zones.csv
timezone: "Europe/Zurich"

# GPIO pin connected to sensor signal via resistor divider (10 kΩ series + 20 kΩ to GND)
# Avoid strapping pins on WROOM (0, 2, 5, 12, 15) and USB pins on S3
# Standard WROOM DevKit v1 / S3-DevKitC-1: GPIO4 works
# TTGO all-in-one board (WROOM + 18650 + OLED): GPIO4/5 are reserved for the onboard
#   OLED (SCL=4, SDA=5) — use GPIO13 or another free pin instead
beam_gpio_pin: GPIO13

# Slack incoming webhook URL (or any HTTP endpoint accepting {"text": "..."})
webhook_url: "https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX"

# Message templates — use {count} as a placeholder for today's crossing count
msg_ok: "All good — {count} crossing(s) today."
msg_low: "Low activity — only {count} crossing(s) today."
msg_zero: "No crossings detected today. Please check in."
